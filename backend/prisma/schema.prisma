generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Student {
  id            String         @id @default(cuid())
  studentId     String         @unique
  name          String
  email         String?        @unique
  phone         String?        @unique
  password      String
  faceEncoding  String?
  isEnrolled    Boolean        @default(true)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  votes         Vote[]
  refreshTokens RefreshToken[]
  deviceTokens  DeviceToken[]
}

model EnrolledStudent {
  id        String   @id @default(cuid())
  studentId String   @unique
  name      String
  course    String
  year      String
  createdAt DateTime @default(now())
}

model Admin {
  id        String   @id @default(cuid())
  username  String   @unique
  password  String
  role      String   @default("admin")
  createdAt DateTime @default(now())
}

model Election {
  id           String      @id @default(cuid())
  blockchainId Int         @unique
  name         String
  isOpen       Boolean     @default(false)
  startTime    DateTime?
  endTime      DateTime?
  createdAt    DateTime    @default(now())
  candidates   Candidate[]
  votes        Vote[]
}

model Candidate {
  id           String   @id @default(cuid())
  blockchainId Int
  electionId   String
  name         String
  position     String
  partylist    String?
  motto        String?
  platforms    String[] 
  photoUrl     String?
  createdAt    DateTime @default(now())
  election     Election @relation(fields: [electionId], references: [id])
  votes        Vote[]
}

model Vote {
  id              String    @id @default(cuid())
  studentId       String
  electionId      String
  candidateId     String
  txHash          String    @unique
  hashedStudentId String
  createdAt       DateTime  @default(now())
  student         Student   @relation(fields: [studentId], references: [id])
  election        Election  @relation(fields: [electionId], references: [id])
  candidate       Candidate @relation(fields: [candidateId], references: [id])
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  studentId String
  expiresAt DateTime
  createdAt DateTime @default(now())
  student   Student  @relation(fields: [studentId], references: [id])
}

model DeviceToken {
  id        String   @id @default(cuid())
  token     String   @unique
  studentId String
  deviceInfo String?
  createdAt DateTime @default(now())
  student   Student  @relation(fields: [studentId], references: [id])
}